APP_NAME="Organization Management Platform"
DEBUG=true
ENVIRONMENT=development

SECRET_KEY=change-me-to-a-64-char-random-secret-minimum-32-bytes

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omp
REDIS_URL=redis://localhost:6379/0

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=1

API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO

VAULT_MASTER_KEY=base64-encoded-32-byte-key-or-use-hex

# Security
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
